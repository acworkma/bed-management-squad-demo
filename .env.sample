# Azure AI Foundry — provide at least one for live agent mode
# Leave both empty to run in simulated mode (no Azure required)
PROJECT_ENDPOINT=
PROJECT_CONNECTION_STRING=

# Model deployment name for AI agents (default: gpt-4o)
MODEL_DEPLOYMENT_NAME=gpt-4o

# JSON mapping of agent name → agent ID (auto-populated by build_agents.py)
# Do not set manually — this is written by the post-provision hook
AGENT_IDS_JSON={}

# UI theme (default: dark)
APP_THEME=dark
